# ------------------------------------------------------------------
# Zkopíruj do `.env` a vyplň reálné hodnoty. `.env` se NEcommituje.
# ------------------------------------------------------------------

# PostgreSQL připojení (lokálně Docker, v produkci Cloud SQL).
# Lokální Docker:
DATABASE_URL="postgresql://datalayer:datalayer@localhost:5432/datalayer?schema=public"
# Cloud SQL přes unix socket (Cloud Run):
# DATABASE_URL="postgresql://app:HESLO@localhost/datalayer?host=/cloudsql/PROJECT:REGION:INSTANCE&schema=public"

# Port (Cloud Run nastavuje automaticky na 8080).
PORT=3000

# Vývojová HTTP Basic Auth ochrana (jako v původním Nette webu).
# Zapni nastavením ENABLE_AUTH=1; jinak je web veřejný.
ENABLE_AUTH=0
SITE_USER="vn"
SITE_PASS="555"

# HubSpot kontaktní formulář.
HUBSPOT_PORTAL_ID="147434044"
HUBSPOT_FORM_ID="8aa3bd5d-8122-47d2-ae62-fa002f6691ca"
HUBSPOT_REGION="eu1"
