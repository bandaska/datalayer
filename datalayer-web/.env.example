# ------------------------------------------------------------------
# Zkopíruj do `.env` a vyplň reálné hodnoty. `.env` se NEcommituje.
# ------------------------------------------------------------------

# --- Firestore (Native) ---
# Na Cloud Run se projekt i přihlášení detekují automaticky (ADC) – nic nenastavuj.
# Lokálně se přihlas přes `gcloud auth application-default login` a nastav projekt:
GOOGLE_CLOUD_PROJECT="datalayer-web"
# FIRESTORE_PROJECT_ID="datalayer-web"   # alternativní override

# Lokální Firestore emulátor (volitelné, místo reálného projektu):
# FIRESTORE_EMULATOR_HOST="localhost:8080"

# Port (Cloud Run nastavuje automaticky na 8080).
PORT=3000

# Vývojová HTTP Basic Auth ochrana (jako v původním Nette webu).
# Zapni nastavením ENABLE_AUTH=1; jinak je web veřejný.
ENABLE_AUTH=0
SITE_USER="vn"
SITE_PASS="555"

# Admin session – podepisování cookie. V produkci NASTAV na náhodný řetězec:
#   openssl rand -base64 32
SESSION_SECRET="dev-secret-change-me"

# HubSpot kontaktní formulář.
HUBSPOT_PORTAL_ID="147434044"
HUBSPOT_FORM_ID="8aa3bd5d-8122-47d2-ae62-fa002f6691ca"
HUBSPOT_REGION="eu1"
